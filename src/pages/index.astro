---
import Base from "../layouts/Base.astro";
import Shell from "../components/Shell.tsx";
import { profile, resume, services, skills, projects, PLACEHOLDER_SLOTS } from "../data";
---

<Base>
  <!-- Semantic, server-rendered fallback: what search engines and no-JS
       visitors get. The interactive OS shell mounts on top when JS loads. -->
  <main class="fallback" id="fallback">
    <header>
      <h1>{profile.name}</h1>
      <p>{profile.role}</p>
      <p>{profile.tagline}</p>
      <p>{profile.location} · <a href={`mailto:${profile.email}`}>{profile.email}</a></p>
      {profile.bio.map((p) => <p>{p}</p>)}
    </header>

    <section>
      <h2>Services</h2>
      {services.map((s) => (
        <article>
          <h3>{s.title}</h3>
          <p>{s.pitch}</p>
          <ul>{s.points.map((pt) => <li>{pt}</li>)}</ul>
        </article>
      ))}
    </section>

    <section>
      <h2>Experience</h2>
      <p>{resume.summary}</p>
      {resume.experience.map((e) => (
        <article>
          <h3>{e.role} — {e.org} <em>({e.period})</em></h3>
          <ul>{e.points.map((pt) => <li>{pt}</li>)}</ul>
        </article>
      ))}
    </section>

    <section>
      <h2>Skills</h2>
      {skills.map((g) => <p><strong>{g.category}:</strong> {g.items.join(", ")}</p>)}
    </section>

    <section>
      <h2>Projects</h2>
      {projects.length === 0 ? (
        <p>Case studies coming soon — {PLACEHOLDER_SLOTS} in progress.</p>
      ) : (
        projects.map((p) => <article><h3>{p.title}</h3><p>{p.summary}</p></article>)
      )}
    </section>
  </main>

  <!-- Interactive OS shell (client-only: no SSR, mounts over the fallback) -->
  <Shell client:only="react" />
</Base>

<style>
  /* Hidden by default (the JS shell covers it); revealed only when JS is off,
     via the no-js flag on <html>. This prevents the fallback from flashing
     before the client-only shell mounts. */
  .fallback { display: none; }
  :global(html.no-js) .fallback {
    display: block;
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 1.25rem;
    line-height: 1.55;
  }
  :global(html.no-js) .fallback h1 { margin-bottom: 0.25rem; }
</style>
