---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Oluwadamilare David — AI Product Engineer",
  description = "AI Product Engineer building complex systems, web apps, and automation. Portfolio presented as the OS you're viewing it on.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <!-- Runs before <body> paints: with JS on, drop the no-js flag so the
         SEO fallback stays hidden and never flashes before the shell mounts. -->
    <script is:inline>document.documentElement.classList.remove("no-js");</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1e3a5f" />
    <meta name="color-scheme" content="light dark" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Warm the two above-the-fold images so they're already cached when their
         React islands request them: the desktop wallpaper (needed the instant the
         shell paints) and the About portrait (the first app most visitors open).
         Without this the wallpaper cache-warmer floods the network first and the
         portrait pops in late. -->
    <link rel="preload" as="image" href="/wallpapers/wall-1.jpg" />
    <link rel="preload" as="image" href="/profile.jpg" />

    <!-- Inline SVG favicon (monogram) — no external request -->
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23005fb8'/%3E%3Ctext x='32' y='42' font-family='Segoe UI,system-ui,sans-serif' font-size='30' font-weight='700' fill='white' text-anchor='middle'%3EOD%3C/text%3E%3C/svg%3E"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
